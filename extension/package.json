{
  "name": "muninn",
  "displayName": "Muninn",
  "description": "Hierarchical notes for VS Code — fuzzy lookup, schema-driven creation, wikilinks.",
  "version": "0.1.1",
  "publisher": "pharomwinters",
  "keywords": [
    "notes",
    "knowledge base",
    "wiki",
    "wikilinks",
    "markdown",
    "pkm",
    "second brain",
    "hierarchical notes",
    "dendron"
  ],
  "homepage": "https://github.com/asgardehs/muninn-vscode#readme",
  "bugs": {
    "url": "https://github.com/asgardehs/muninn-vscode/issues"
  },
  "qna": "https://github.com/asgardehs/muninn-vscode/discussions",
  "author": {
    "name": "Adam Bick",
    "email": "adam.bick86@gmail.com"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asgardehs/muninn-vscode.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:**/.muninn/",
    "workspaceContains:**/*.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "muninn.lookup",
        "title": "Muninn: Lookup",
        "icon": "$(search)"
      },
      {
        "command": "muninn.lookupHere",
        "title": "Muninn: Lookup Under Current Note"
      },
      {
        "command": "muninn.refreshVault",
        "title": "Muninn: Refresh Vault Index",
        "icon": "$(refresh)"
      },
      {
        "command": "muninn.installSchemaPack",
        "title": "Muninn: Install Schema Pack"
      },
      {
        "command": "muninn.ping",
        "title": "Muninn: Ping Sidecar"
      },
      {
        "command": "muninn.showSidecarLogs",
        "title": "Muninn: Show Sidecar Logs"
      }
    ],
    "keybindings": [
      {
        "command": "muninn.lookup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus || !editorFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "muninn",
          "title": "Muninn",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "muninn": [
        {
          "id": "muninn.hierarchyView",
          "name": "Hierarchy",
          "contextualTitle": "Muninn"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "muninn.refreshVault",
          "when": "view == muninn.hierarchyView",
          "group": "navigation"
        },
        {
          "command": "muninn.lookup",
          "when": "view == muninn.hierarchyView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Muninn",
      "properties": {
        "muninn.sidecarPath": {
          "type": "string",
          "default": "",
          "description": "Override path to the muninn-sidecar binary (for development). Empty = use bundled binary."
        },
        "muninn.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Log verbosity for the Muninn output channel."
        },
        "muninn.diagnostics.unresolvedLinks": {
          "type": "boolean",
          "default": true,
          "description": "Show diagnostics for unresolved [[wikilinks]] and missing heading fragments."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node20 --sourcemap",
    "watch": "npm run compile -- --watch",
    "typecheck": "tsc --noEmit -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
